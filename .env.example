# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
BOT_TOKEN=

# ── Telegram MTProto ──────────────────────────────────────────────────────────
# Get from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Path for the session file (no extension). Created once via `go run ./cmd/setup`
SESSION_NAME=session/userbot

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
# Max messages to fetch per channel on each sync (default: 500)
MAX_MESSAGES_PER_CHANNEL=500
